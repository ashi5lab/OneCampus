DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=replace-with-a-long-random-string
PORT=3001
# All optional, shown with their defaults:
# CLIENT_ORIGIN=http://localhost:5173
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL_DAYS=7
# TENANT_BASE_DOMAIN=onecampus.local
# SUPER_ADMIN_TOKEN_TTL=12h
#
# File uploads to Cloudflare R2 (server/lib/storage.js)
# — omit to leave uploads disabled (503).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
#
# Meta WhatsApp Cloud API webhooks (server/modules/webhooks/whatsapp.js)
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: any string you choose — enter the same
#   value as "Verify token" when configuring the callback URL in the Meta
#   app dashboard. Verification is rejected until this is set.
# META_APP_SECRET: the app's App Secret (App settings → Basic) — enables
#   X-Hub-Signature-256 validation of event payloads. Optional during
#   setup; strongly recommended in production.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=onecampus_verify_2026
# META_APP_SECRET=
