DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=replace-with-a-long-random-string
PORT=3001
# All optional, shown with their defaults:
# CLIENT_ORIGIN=http://localhost:5173
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL_DAYS=7
# TENANT_BASE_DOMAIN=onecampus.local
# SUPER_ADMIN_TOKEN_TTL=12h
#
# Profile picture uploads (server/modules/profile, server/lib/cloudinary.js)
# — omit all three to leave uploads disabled (503). If this Cloudinary
# account/cloud is shared with other apps, uploads from here are already
# namespaced under an "onecampus/" folder regardless of these values.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
