VITE_API_BASE_URL=http://localhost:3001/api/v1
# Only needed for local dev, where the browser's Host header won't match a
# real tenant domain — sent as x-tenant-domain on every request. In
# production a tenant instead types their domain on the login page (see
# apiClient.js's setTenantDomain), which takes precedence over this.
VITE_TENANT_DOMAIN=dev.onecampus.local
# Cosmetic only — used to preview the domain a registering tenant will get
# (must match the server's TENANT_BASE_DOMAIN to be accurate).
VITE_TENANT_BASE_DOMAIN=onecampus.local
